# Upstash Redis — https://console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# JWT secret — any long random string, e.g.: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Apple bundle ID — must match your Xcode project (e.g. com.tutorly.app)
APPLE_BUNDLE_ID=com.tutorly.app
